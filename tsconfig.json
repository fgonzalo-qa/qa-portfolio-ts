{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@pages/*":    ["pages/*"],
      "@fixtures/*": ["fixtures/*"],
      "@utils/*":    ["utils/*"],
      "@types/*":    ["types/*"]
    }
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules"]
}